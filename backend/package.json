{
  "name": "bimusic-backend",
  "version": "0.1.0",
  "description": "BiMusic REST API backend",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "express": "^5.0.0",
    "fluent-ffmpeg": "^2.1.0",
    "jsonwebtoken": "^9.0.0",
    "pino": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/fluent-ffmpeg": "^2.1.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/nock": "^10.0.3",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^8.57.0",
    "nock": "^14.0.11",
    "pino-pretty": "^11.0.0",
    "prettier": "^3.2.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  }
}
