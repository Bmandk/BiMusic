# Server
PORT=3000
NODE_ENV=development

# Database
DB_PATH=./data/bimusic.db

# JWT (see docs/architecture-decisions.md)
JWT_ACCESS_SECRET=change-me-access-secret-must-be-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# Logging
LOG_PATH=./logs

# Lidarr
LIDARR_URL=http://localhost:8686
LIDARR_API_KEY=your-lidarr-api-key

# Music library (bind-mounted from host, read-only)
MUSIC_LIBRARY_PATH=/music

# Offline storage (transcoded files per user)
OFFLINE_STORAGE_PATH=./data/offline

# Temp files (seek support for non-MP3 sources)
TEMP_DIR=/tmp/bimusic

# Admin bootstrap (used on first startup only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Public base URL of this server (used to generate imageUrl and streamUrl in API responses)
API_BASE_URL=http://localhost:3000
